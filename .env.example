# PostgreSQL Configuration
POSTGRES_PASSWORD=postgres_password_here
POSTGRES_DB=analytics
POSTGRES_USER=postgres

# Producer Configuration
PRODUCER_THROUGHPUT=500
PRODUCER_ANOMALY_RATE=0.005

# Consumer Configuration
CONSUMER_GROUP_ID=ecommerce-consumer-group
CONSUMER_BATCH_SIZE=500

# Anomaly Detection Configuration
ANOMALY_CONTAMINATION=0.01
ANOMALY_POLLING_INTERVAL=60
ANOMALY_WINDOW_SIZE=500

# Grafana Configuration
GF_SECURITY_ADMIN_PASSWORD=admin
GF_SECURITY_ADMIN_USER=admin

# Slack Alerting (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Prometheus Configuration
PROMETHEUS_PORT=9090
ANOMALY_METRICS_PORT=8000

# dbt Configuration
DBT_PROFILES_DIR=./dbt
DBT_PROJECT_DIR=./dbt

# Docker Configuration
COMPOSE_PROJECT_NAME=ecommerce-analytics